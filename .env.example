# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=artwork.kapa-oil.com,10.0.0.7,10.10.1.18,Kapa-apps-07

# Site
SITE_URL=https://artwork.kapa-oil.com

# Database
DB_ENGINE=postgres
DB_NAME=artwork
DB_USER=artwork_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Email
EMAIL_HOST=10.0.0.25
EMAIL_PORT=25
EMAIL_HOST_USER=kapaportal@kapa-oil.local
DEFAULT_FROM_EMAIL=kapaportal@kapa-oil.local

# Development only — redirect all alerts to this inbox (see config/settings/development.py)
DEV_EMAIL_OVERRIDE=support.user5@kapa-oil.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# PDF
WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf

# Active Directory / LDAP
LDAP_ENABLED=true
LDAP_SERVER_URI=ldap://10.0.0.4:389
LDAP_BIND_DN=
LDAP_PASSWORD=
LDAP_BASE_DN=DC=kapa-oil,DC=local
LDAP_USER_DOMAIN=kapa-oil.local
LDAP_DOMAIN_NETBIOS=KAPA-OIL

# S3-compatible storage (MinIO, AWS S3, etc.)
USE_S3=true
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=kapa-artwork
AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=https://minio.kapa-oil.com

# SSL
SECURE_SSL_REDIRECT=true
