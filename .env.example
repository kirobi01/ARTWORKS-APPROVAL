# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=10.0.0.27,artwork.kapa-oil.com

# Site (Artwork runs on port 8027 so other apps keep 80/443)
SITE_URL=http://10.0.0.27:8027
CSRF_TRUSTED_ORIGINS=http://10.0.0.27:8027

# Database — Postgres on the same host (preferred) or another server
DB_ENGINE=postgres
DB_NAME=ARTWORK
DB_USER=admin
DB_PASSWORD=
DB_HOST=host.docker.internal
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Email
EMAIL_HOST=10.0.0.25
EMAIL_PORT=25
EMAIL_HOST_USER=kapaportal@kapa-oil.local
DEFAULT_FROM_EMAIL=kapaportal@kapa-oil.local

# Development only
DEV_EMAIL_OVERRIDE=support.user5@kapa-oil.com

# Celery (docker-compose points these at the private redis service)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# PDF
WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf

# Active Directory / LDAP
LDAP_ENABLED=true
LDAP_SERVER_URI=ldap://10.0.0.4:389
LDAP_BIND_DN=
LDAP_PASSWORD=
LDAP_BASE_DN=DC=kapa-oil,DC=local
LDAP_USER_DOMAIN=kapa-oil.local
LDAP_DOMAIN_NETBIOS=KAPA-OIL

# Local media volume in Docker (set true later when MinIO/S3 is ready)
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=kapa-artwork
AWS_S3_REGION_NAME=us-east-1

# HTTP for now (no takeover of host TLS/80)
SECURE_SSL_REDIRECT=false
